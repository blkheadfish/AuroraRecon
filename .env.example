# ===================================================
# PentestAI v2.0 环境变量配置
# 复制为 docker/.env 并修改必要的值
# ===================================================

# ── 大模型配置（必填）─────────────────────────────────
LLM_PROVIDER=deepseek          # deepseek | openai | anthropic
LLM_API_KEY=sk-your-api-key
LLM_MODEL=deepseek-v4-flash
LLM_BASE_URL=https://api.deepseek.com
LLM_MAX_TOKENS=4096

# ── 安全配置 ─────────────────────────────────────────
# JWT 签名密钥（至少 32 字符；未设置或太短时自动生成随机值，重启后 token 失效）
# 生成方法: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=HRrmf3X2NWfU8LnUIjuSXo8McyRJHtjNKyq6FiygGNQ
# CORS 允许来源（逗号分隔，默认 * 允许所有；生产环境应限制为前端域名）
CORS_ORIGINS=http://localhost:5173

# ── Metasploit RPC ────────────────────────────────────
MSF_PASSWORD=pentest123

# ── 反弹 Shell 接收地址（必填：改为攻击机公网 IP）────
LHOST=127.0.0.1

# ── PostgreSQL ────────────────────────────────────────
# 完整连接字符串（推荐），设置后 POSTGRES_PASSWORD 可忽略
DATABASE_URL=postgresql+asyncpg://pentest:pentest123@localhost:5432/pentestai
POSTGRES_PASSWORD=pentest123

# ── MinIO（对象存储）──────────────────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ── Redis 连接池 ─────────────────────────────────────
# 短操作 (publish / cache) 池: 用完即还, 不需要太多
REDIS_MAX_CONNECTIONS=100
# XREAD BLOCK 长连接池: 每个 WS Tab 持有 1 条连接 25s, 默认 500 覆盖 ~400 并发 Tab
REDIS_XREAD_MAX_CONNECTIONS=500

# ── 实时推送协议 (v2 Redis Stream) ────────────────────
# 协议版本: 2=Redis Stream 单一事件源 (默认), 回退到 1 可走老协议
REALTIME_PROTOCOL_VERSION=2
# 单任务 Stream 最大事件数 (近似裁剪), 超过则 XADD MAXLEN ~ 丢最旧
EVENT_STREAM_MAXLEN=50000
# Stream 空闲 TTL (秒), 任务结束后 7 天自动回收
EVENT_STREAM_TTL=604800
# XREAD BLOCK 超时 (毫秒), 与客户端心跳 25s 对齐
EVENT_STREAM_BLOCK_MS=25000

# ── Docker（工具沙箱）─────────────────────────────────
TOOLBOX_IMAGE=pentest-toolbox:latest
DOCKER_NETWORK=pentest_net
USE_HOST_TOOLS=false
MAX_TOOL_TIMEOUT=360
MAX_STAGE_RUNTIME=900
