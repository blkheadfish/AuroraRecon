  "detection_method": "发送GET请求到 http://{TARGET}/invoker/JMXInvokerServlet，如果返回HTTP 200状态码且响应头包含 Content-Type: application/x-java-serialized-object，则可能存在漏洞",
  "probes": [
    {
      "id": "jboss_jmxinvoker_probe",
      "description": "GET /invoker/JMXInvokerServlet，观察 java-serialized-object Content-Type",
      "method": "GET",
      "path": "/invoker/JMXInvokerServlet",
      "timeout": 8,
      "success_signs": {
        "header_contains": [
          [
            "Content-Type",
            "application/x-java-serialized-object"
          ]
        ]
      },
      "confidence": 0.9
    }
  ],
  "verification_command": "curl -X POST --data-binary @payload.ser http://{TARGET}/invoker/JMXInvokerServlet -H \"Content-Type: application/x-java-serialized-object\"",
  "verification_success_sign": "返回HTTP 200状态码，且目标服务器上执行了payload中的命令（如创建文件、执行系统命令等）",
  "requires_callback": false,
  "callback_note": "该漏洞本身不需要目标回连，但payload可以包含反弹shell命令，此时需要监听端口。替代方案：使用无回连的payload验证漏洞存在，如创建文件、执行whoami等命令",
  "remediation": "1. 升级到JBoss AS 7.x或更高版本；2. 删除或限制访问/invoker/JMXInvokerServlet；3. 添加安全过滤器阻止反序列化攻击；4. 更新Java环境，使用安全版本的commons-collections库",
  "tags": [
    "jboss",
